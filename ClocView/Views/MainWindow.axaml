<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:s="http://smart/avalonia"
        xmlns:behaviors="clr-namespace:ClocView.Behaviors"
        xmlns:views="clr-namespace:ClocView.Views"
        mc:Ignorable="d"
        x:Class="ClocView.Views.MainWindow"
        x:DataType="views:MainWindowViewModel"
        s:DataContextResolver.Type="views:MainWindowViewModel"
        Width="1200"
        Height="768"
        d:DesignWidth="1200" d:DesignHeight="768"
        CanResize="True"
        Title="ClocView"
        Icon="/Assets/avalonia-logo.ico">

    <Interaction.Behaviors>
        <behaviors:LoadedCommandBehavior Command="{Binding LoadedCommand}" />
        <behaviors:WindowDragDropBehavior DropCommand="{Binding DropCommand}" />
    </Interaction.Behaviors>

    <Window.DataContext>
        <views:MainWindowViewModel />
    </Window.DataContext>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Command="{Binding ExecuteCommand}"
                          Header="_Refresh" />
                <MenuItem Command="{Binding CancelCommand}"
                          Header="_Cancel" />
                <Separator />
                <MenuItem Command="{Binding ExportCsvCommand}"
                          Header="Save as _CSV..." />
                <Separator />
                <MenuItem Command="{Binding ExitCommand}"
                          Header="E_xit" />
            </MenuItem>
        </Menu>

        <!-- Directory input -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DirectoryTextBox"
                     Grid.Column="0"
                     Padding="4,2"
                     Text="{Binding TargetDirectory}"
                     VerticalContentAlignment="Center">
                <Interaction.Behaviors>
                    <behaviors:TextBoxEnterKeyBehavior Command="{Binding ExecuteCommand}" />
                </Interaction.Behaviors>
            </TextBox>
            <Button Grid.Column="1"
                    Margin="2,0,0,0"
                    Padding="10,3"
                    Command="{Binding SelectDirectoryCommand}"
                    Content="..." />
            <Button Grid.Column="2"
                    Margin="2,0,0,0"
                    Padding="10,3"
                    Command="{Binding ExecuteCommand}"
                    Content="Refresh" />
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="MainGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  SelectionMode="Extended">
            <Interaction.Behaviors>
                <behaviors:DataGridDeleteKeyBehavior Command="{Binding DeleteCommand}" />
            </Interaction.Behaviors>
            <DataGrid.Columns>
                <DataGridTextColumn Width="120"
                                    Binding="{ReflectionBinding Language}"
                                    Header="Language" />
                <DataGridTextColumn Width="*"
                                    Binding="{ReflectionBinding RelativePath}"
                                    Header="Path" />
                <DataGridTextColumn Width="70"
                                    Binding="{ReflectionBinding Blank}"
                                    Header="Blank" />
                <DataGridTextColumn Width="80"
                                    Binding="{ReflectionBinding Comment}"
                                    Header="Comment" />
                <DataGridTextColumn Width="80"
                                    Binding="{ReflectionBinding Code}"
                                    Header="Code" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Progress indicator -->
        <ProgressBar Grid.Row="2"
                     Height="3"
                     VerticalAlignment="Top"
                     IsVisible="{Binding BusyState.IsBusy}"
                     IsIndeterminate="True" />

        <!-- Status bar -->
        <Border Grid.Row="3"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
            <Grid Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusMessage}" />
                <TextBlock Grid.Column="1"
                           Margin="8,0"
                           VerticalAlignment="Center"
                           Text="{Binding TotalBlank, StringFormat='Blank: {0}'}" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding TotalComment, StringFormat='Comment: {0}'}" />
                <TextBlock Grid.Column="3"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Text="{Binding TotalCode, StringFormat='Code: {0}'}" />
            </Grid>
        </Border>
    </Grid>

</Window>
