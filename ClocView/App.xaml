<Application xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:s="http://smart/windows"
             x:Class="ClocView.App"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <s:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"
                                     TrueValue="Visible"
                                     FalseValue="Hidden" />

        <!-- Color palette -->
        <Color x:Key="RowAltColor">#F2F6FB</Color>
        <Color x:Key="RowSelectedColor">#C7DEFF</Color>
        <Color x:Key="RowHoverColor">#E3EEFF</Color>
        <Color x:Key="HeaderBackColor">#2C5F8A</Color>
        <Color x:Key="HeaderForeColor">#FFFFFF</Color>
        <Color x:Key="GridLineColor">#D0D8E4</Color>
        <SolidColorBrush x:Key="RowAltBrush" Color="{StaticResource RowAltColor}" />
        <SolidColorBrush x:Key="RowSelectedBrush" Color="{StaticResource RowSelectedColor}" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="{StaticResource RowHoverColor}" />
        <SolidColorBrush x:Key="HeaderBackBrush" Color="{StaticResource HeaderBackColor}" />
        <SolidColorBrush x:Key="HeaderForeBrush" Color="{StaticResource HeaderForeColor}" />
        <SolidColorBrush x:Key="GridLineBrush" Color="{StaticResource GridLineColor}" />

        <!-- DataGridColumnHeader style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBackBrush}" />
            <Setter Property="Foreground" Value="{StaticResource HeaderForeBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <!-- DataGridRow style with alternation and hover -->
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource RowAltBrush}" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource RowSelectedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGridCell style — zero padding, left border for vertical grid line -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{x:Static SystemColors.ControlTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Right-aligned cell (for numeric columns) -->
        <Style x:Key="NumericCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="TextBlock.TextAlignment" Value="Right" />
        </Style>
    </Application.Resources>
</Application>
