<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:s="http://smart/windows"
        xmlns:views="clr-namespace:ClocView.Views"
        xmlns:behaviors="clr-namespace:ClocView.Behaviors"
        mc:Ignorable="d"
        x:Class="ClocView.Views.MainWindow"
        d:DataContext="{d:DesignInstance Type={x:Type views:MainWindowViewModel}}"
        Width="1200"
        Height="768"
        Title="ClocView"
        Icon="../App.ico"
        ResizeMode="CanResizeWithGrip">

    <Window.DataContext>
        <views:MainWindowViewModel />
    </Window.DataContext>

    <i:Interaction.Triggers>
        <!-- Lifecycle -->
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closing">
            <s:CancelEventAction Cancel="{Binding BusyState.IsBusy}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="Closed">
            <s:DataContextDisposeAction />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <i:Interaction.Behaviors>
        <!-- Drag and Drop -->
        <behaviors:FileDragDropBehavior DropCommand="{Binding DropCommand}" />
    </i:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Command="{Binding ExecuteCommand}"
                          Header="_Refresh" />
                <Separator />
                <MenuItem Command="{Binding ExportCsvCommand}"
                          Header="Save as _CSV..." />
                <Separator />
                <MenuItem Command="{Binding ExitCommand}"
                          Header="E_xit" />
            </MenuItem>
        </Menu>

        <!-- Directory input -->
        <Grid Grid.Row="1"
              Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Padding="4,2"
                     Text="{Binding TargetDirectory, UpdateSourceTrigger=PropertyChanged}"
                     BorderThickness="0,0,0,1"
                     VerticalContentAlignment="Center">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return"
                                Command="{Binding ExecuteCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1"
                    Margin="1,0,0,0"
                    Padding="10,3"
                    Command="{Binding SelectDirectoryCommand}"
                    Content="..." />
            <Button Grid.Column="2"
                    Margin="1,0,0,0"
                    Padding="10,3"
                    Command="{Binding ExecuteCommand}"
                    Content="Refresh" />
        </Grid>

        <!-- DataGrid -->
        <DataGrid x:Name="MainGrid"
                  Grid.Row="2"
                  Margin="0"
                  ItemsSource="{Binding Records}"
                  AlternationCount="2"
                  AutoGenerateColumns="False"
                  Background="White"
                  CanUserAddRows="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  EnableRowVirtualization="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                  IsReadOnly="True"
                  SelectionMode="Extended">
            <i:Interaction.Behaviors>
                <behaviors:DataGridDeleteKeyBehavior DeleteCommand="{Binding DeleteCommand}" />
            </i:Interaction.Behaviors>
            <DataGrid.Columns>
                <DataGridTextColumn Width="120"
                                    Binding="{Binding Language}"
                                    Header="Language" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding RelativePath}"
                                    Header="Path" />
                <DataGridTextColumn Width="70"
                                    Binding="{Binding Blank}"
                                    CellStyle="{StaticResource NumericCellStyle}"
                                    Header="Blank" />
                <DataGridTextColumn Width="80"
                                    Binding="{Binding Comment}"
                                    CellStyle="{StaticResource NumericCellStyle}"
                                    Header="Comment" />
                <DataGridTextColumn Width="80"
                                    Binding="{Binding Code}"
                                    CellStyle="{StaticResource NumericCellStyle}"
                                    Header="Code" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <StatusBar Grid.Row="3"
                   BorderBrush="{StaticResource GridLineBrush}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="4,0"
                               VerticalAlignment="Center"
                               Text="{Binding StatusMessage}" />
                    <TextBlock Grid.Column="1"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalBlank, StringFormat='Blank: {0}'}" />
                    <TextBlock Grid.Column="2"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalComment, StringFormat='Comment: {0}'}" />
                    <TextBlock Grid.Column="3"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Text="{Binding TotalCode, StringFormat='Code: {0}'}" />
                </Grid>
            </StatusBarItem>
        </StatusBar>

        <!-- Progress indicator (thin bar at top of grid area) -->
        <ProgressBar Grid.Row="2"
                     Height="3"
                     Margin="0"
                     VerticalAlignment="Top"
                     Visibility="{Binding BusyState.IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                     IsIndeterminate="True" />
    </Grid>

</Window>
